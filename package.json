{
  "name": "upgrade-self",
  "version": "0.0.1",
  "description": "Reusable upgrade core for Node.js CLIs that checks npm versions, plans installs, and schedules detached self-upgrades.",
  "type": "module",
  "keywords": [
    "update",
    "upgrade",
    "cli",
    "npm",
    "node",
    "self-update",
    "version-check"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Cweili/upgrade-self.git"
  },
  "author": "Cweili",
  "license": "MIT",
  "homepage": "https://github.com/Cweili/upgrade-self#readme",
  "bugs": {
    "url": "https://github.com/Cweili/upgrade-self/issues"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "clean": "rimraf coverage dist",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "build": "tsdown",
    "test": "c8 --reporter=lcov --reporter=text node --import tsx --test \"tests/**/*.test.ts\"",
    "check": "npm run lint && npm run build && npm test"
  },
  "dependencies": {
    "semver": "^7.7.3"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@types/node": "^24.10.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "c8": "^11.0.0",
    "eslint": "^10.4.1",
    "rimraf": "^6.1.0",
    "tsdown": "^0.22.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
